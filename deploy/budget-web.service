[Unit]
Description=Budget Notebook - web (API + frontend)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=brunobarroso
WorkingDirectory=/home/brunobarroso/Desktop/telegram-expense-tracker
ExecStart=/home/brunobarroso/Desktop/telegram-expense-tracker/.venv/bin/python -m uvicorn api.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
